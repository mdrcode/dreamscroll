<!DOCTYPE html>
<html>

<head>
    <title>dreamscroll - {{ capture.id }}</title>
    <link rel="stylesheet" href="/static/v1/common.css">
    <style>
        #page-content-container {
            max-width: 960px;
        }

        .detail-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .image-container {
            display: flex;
            justify-content: center;
            align-items: center;
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 20px;
        }

        .image-container img {
            max-width: 100%;
            height: auto;
            max-height: 800px;
            object-fit: contain;
        }

        .metadata {
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        .metadata h2 {
            margin-top: 0;
            font-size: 18px;
        }

        .metadata-row {
            margin: 10px 0;
        }

        .metadata-label {
            font-weight: 600;
            color: #666;
        }
    </style>
</head>

<body>
    <div id="page-content-container">
        <div id="header-row">
            <h1 id="page-title">dreamscroll - {{ capture.id }}</h1>
        </div>

        <div class="back-link">
            <a href="/">← Back</a>
        </div>

        <div class="detail-container">
            <div class="image-container">
                <img src="/media/{{ capture.medias[0].filename }}" alt="{{ capture.medias[0].filename }}">
            </div>

            <div class="metadata">
                <h2>Image Details</h2>
                <div class="metadata-row">
                    <span class="metadata-label">Filename:</span> {{ capture.medias[0].filename }}
                </div>
                <div class="metadata-row">
                    <span class="metadata-label">Uploaded:</span> {{ capture.created_at }}
                </div>
                <div class="metadata-row">
                    {% if capture.illuminations %}
                    <span class="metadata-label">Illumination:</span>
                    {{ capture.illuminations[0].content }}
                    {% else %}
                    No illumination data available.
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</body>

</html>