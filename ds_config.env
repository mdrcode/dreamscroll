# !!! put secrets in ds_secrets.env (.gitignore'd) to avoid leaking them via git
#DREAMSCROLL_ILLUMINATOR_GEMINI_KEY=NOT_HERE
#DREAMSCROLL_JWT_SECRET=NOT_HERE
#DREAMSCROLL_DB_URL_POSTGRES=NOT_HERE
# !!!

DREAMSCROLL_WEB_PORT=8888
DREAMSCROLL_TRACING_MAX_LEVEL=info

DREAMSCROLL_DB_BACKEND=sqlite
DREAMSCROLL_DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc

DREAMSCROLL_STORAGE_BACKEND=gcloud

DREAMSCROLL_STORAGE_LOCAL_FILE_PATH="localdev/local_storage_provider"
DREAMSCROLL_STORAGE_LOCAL_URL_PREFIX="/media/"

DREAMSCROLL_STORAGE_GCLOUD_EMULATOR_ENDPOINT="http://localhost:4443"
DREAMSCROLL_STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"