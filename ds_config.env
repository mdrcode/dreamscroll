# !!! put secrets in ds_secrets.env instead (.gitignore) to avoid leaking them via git
#DREAMSCROLL_ILLUMINATOR_GEMINI_KEY
#DREAMSCROLL_JWT_SECRET
#DREAMSCROLL_DB_URL_POSTGRES
# !!!

DREAMSCROLL_WEB_PORT=8888
DREAMSCROLL_TRACING_MAX_LEVEL=info

DREAMSCROLL_DB_BACKEND=sqlite
DREAMSCROLL_DB_URL_SQLITE=sqlite://localdev/dreamscroll.db

DREAMSCROLL_STORAGE_BACKEND=gcloud
DREAMSCROLL_STORAGE_LOCAL_PATH="localdev/local_storage_provider"
DREAMSCROLL_STORAGE_GCLOUD_EMULATOR_ENDPOINT="http://localhost:4443"
DREAMSCROLL_STORAGE_GCLOUD_BUCKET_NAME="some-bucket"
DREAMSCROLL_STORAGE_URL_LOCAL_PREFIX="/media/"