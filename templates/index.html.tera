<!DOCTYPE html>
<html>

<head>
    <title>dreamscroll</title>
    <style>
        body {
            display: flex;
            justify-content: center;

            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
            font-weight: 400;
            line-height: 1.6;
        }

        #page-content-container {
            display: flex;
            flex-direction: column;
            width: 80%;
            min-width: 480px;
            max-width: 800px;
        }

        #header-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            /* due to padding in .image-row below... */
            width: calc(100% + 20px);
            margin-top: 12px;
            margin-bottom: 20px;
        }

        #page-title {
            margin: 0;
            font-size: xx-large;
            line-height: 1.0;
        }

        #file-upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #file-picker-label {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #file-picker-label:hover {
            border-color: #999;
        }

        #drop-zone-row {
            display: none;
            width: 100%;
            text-align: center;
            font-size: 18px;
            background-color: #f9f9f9;
            color: #666;

            padding: 20px 0;
            margin-bottom: 20px;

            border: 2px dashed #ccc;
            border-radius: 8px;
        }

        #drop-zone.drag-over {
            display: block;
            border-color: #999;
            background-color: #f0f0f0;
        }

        .image-row {
            width: 100%;
            display: flex;
            flex-direction: row;
            border: 1px solid #ccc;
            border-radius: 8px;
            gap: 10px;
            padding: 10px;
            margin-bottom: 10px;

        }

        .image-actual-wrapper {
            width: 55%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .image-actual {
            width: 100%;
            height: auto;
            max-height: 540px;
            object-fit: contain;

            cursor: pointer;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }

        .image-actual:hover {
            box-shadow: 0 6px 10px rgba(0, 0, 0, 0.1);
        }

        .image-metadata-wrapper {
            width: 45%;
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            margin-left: 10px;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filePicker = document.getElementById('file-picker');
            const uploadForm = document.getElementById('file-upload-form');
            const dropZone = document.getElementById('drop-zone-row');

            filePicker.addEventListener('change', function () {
                this.form.submit();
            });

            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';

            // Drag and drop functionality
            ['dragenter', 'dragover'].forEach(eventName => {
                document.body.addEventListener(eventName, function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.style.display = 'block';
                    dropZone.classList.add('drag-over');
                });
            });

            ['dragleave', 'dragend'].forEach(eventName => {
                document.body.addEventListener(eventName, function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropZone.style.display = 'none';
                    dropZone.classList.remove('drag-over');
                });
            });

            document.body.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropZone.style.display = 'none';
                dropZone.classList.remove('drag-over');

                const files = e.dataTransfer.files;
                if (files.length > 0 && files[0].type.startsWith('image/')) {
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(files[0]);
                    filePicker.files = dataTransfer.files;
                    uploadForm.submit();
                }
            });
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">dreamscroll</h1>

            <form id="file-upload-form" action="/upload" method="post" enctype="multipart/form-data">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker">Upload ⇧</label>
                <div id="submit-btn-container">
                    <br>
                    <input id="submit-btn" type="submit" value="Submit">
                </div>
            </form>
        </div>

        <div id="drop-zone-row">
            Drop image anywhere to upload
        </div>

        {% for i in images %}

        <div class="image-row">
            <div class="image-actual-wrapper">
                <a href="/detail/{{ i.filename }}" style="text-decoration: none; color: inherit;">
                    <img class="image-actual" src="/uploads/{{ i.filename }}" alt="image {{i.filename}}">
                </a>
            </div>
            <div class="image-metadata-wrapper">
                <div class="image-metadata">
                    {{ i.timestamp }}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>