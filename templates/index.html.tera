<!DOCTYPE html>
<html>

<head>
    <title>dreamscroll</title>
    <style>
        body {
            display: flex;
            justify-content: center;

            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
            font-weight: 400;
            line-height: 1.6;
        }

        #page-content-container {
            display: flex;
            flex-direction: column;
            width: 80%;
            min-width: 480px;
            max-width: 800px;
        }

        #header-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            /* due to padding in .image-row below... */
            width: calc(100% + 20px);
            margin-top: 12px;
            margin-bottom: 20px;
        }

        #page-title {
            margin: 0;
            font-size: xx-large;
            line-height: 1.0;
        }

        #file-upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #file-picker-label {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #file-picker-label:hover {
            border-color: #999;
        }

        #drop-zone-row {
            display: none;
            width: 100%;
            text-align: center;
            font-size: 18px;
            background-color: #f9f9f9;
            color: #666;

            padding: 20px 0;
            margin-bottom: 20px;

            border: 2px dashed #ccc;
            border-radius: 8px;
        }

        #drop-zone.drag-over {
            display: block;
            border-color: #999;
            background-color: #f0f0f0;
        }

        .image-row {
            width: 100%;
            display: flex;
            flex-direction: row;
            border: 1px solid #ccc;
            border-radius: 8px;
            gap: 10px;
            padding: 10px;
            margin-bottom: 10px;

        }

        .image-actual-wrapper {
            width: 55%;
            display: flex;
            justify-content: center;
            align-items: start;
        }

        .image-actual {
            width: 100%;
            height: auto;
            max-height: 540px;
            object-fit: contain;

            cursor: pointer;
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }

        .image-actual:hover {
            box-shadow: 0 6px 10px rgba(0, 0, 0, 0.1);
        }

        .image-metadata-wrapper {
            width: 45%;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            margin-left: 10px;
        }

        .details-container {
            position: relative;
        }

        .details-text {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .details-text.expanded {
            max-height: 1000px;
        }

        .toggle-details {
            color: #585f67;
            cursor: pointer;
            text-decoration: underline;
            font-size: 14px;
            margin-top: 4px;
        }

        .toggle-details:hover {
            color: #0056b3;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filePicker = document.getElementById('file-picker');
            const uploadForm = document.getElementById('file-upload-form');
            const dropZone = document.getElementById('drop-zone-row');
            let dragCounter = 0;

            filePicker.addEventListener('change', function () {
                this.form.submit();
            });

            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';

            // Drag and drop functionality
            document.body.addEventListener('dragenter', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter++;
                if (dragCounter === 1) {
                    dropZone.style.display = 'block';
                    dropZone.classList.add('drag-over');
                }
            });

            document.body.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
            });

            document.body.addEventListener('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter--;
                if (dragCounter === 0) {
                    dropZone.style.display = 'none';
                    dropZone.classList.remove('drag-over');
                }
            });

            document.body.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter = 0;
                dropZone.style.display = 'none';
                dropZone.classList.remove('drag-over');

                const files = e.dataTransfer.files;
                if (files.length > 0 && files[0].type.startsWith('image/')) {
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(files[0]);
                    filePicker.files = dataTransfer.files;
                    uploadForm.submit();
                }
            });

            document.querySelectorAll('.toggle-details').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const detailsText = this.previousElementSibling;
                    detailsText.classList.toggle('expanded');
                    this.textContent = detailsText.classList.contains('expanded') ? 'See Less...' : 'See More...';
                });
            });
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">dreamscroll</h1>

            <form id="file-upload-form" action="/upload" method="post" enctype="multipart/form-data">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker">Upload ⇧</label>
                <div id="submit-btn-container">
                    <br>
                    <input id="submit-btn" type="submit" value="Submit">
                </div>
            </form>
        </div>

        <div id="drop-zone-row">
            Drop image anywhere to upload
        </div>

        {% for capture in capture_infos %}

        <div class="image-row">
            <div class="image-actual-wrapper">
                <a href="/detail/{{ capture.id }}" style="text-decoration: none; color: inherit;">
                    <img class="image-actual" src="/media/{{ capture.medias[0].filename }}"
                        alt="image {{ capture.medias[0].filename }}">
                </a>
            </div>
            <div class="image-metadata-wrapper">
                {{ capture.created_at }}

                {% if capture.summary %}
                <p>
                    {{ capture.summary }}
                </p>
                {% endif %}

                {% if capture.details %}
                <div class="details-container">
                    <div class="details-text">
                        <p>{{ capture.details }}</p>
                    </div>
                    <a href="#" class="toggle-details">See More...</a>
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>