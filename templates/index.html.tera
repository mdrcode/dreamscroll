<!DOCTYPE html>
<html>

<head>
    <title>dreamscroll</title>
    <link rel="stylesheet" href="/static/v1/common.css">
    <link rel="stylesheet" href="/static/v1/capturelist.css">
    <style>
        #page-content-container {
            width: 80%;
            min-width: 480px;
            max-width: 800px;
        }

        #file-upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #file-picker-label {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #file-picker-label:hover {
            border-color: #999;
        }

        #drop-zone-row {
            display: none;
            width: 100%;
            text-align: center;
            font-size: 18px;
            background-color: #f9f9f9;
            color: #666;

            padding: 20px 0;
            margin-bottom: 20px;

            border: 2px dashed #ccc;
            border-radius: 8px;
        }

        #drop-zone.drag-over {
            display: block;
            border-color: #999;
            background-color: #f0f0f0;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const filePicker = document.getElementById('file-picker');
            const uploadForm = document.getElementById('file-upload-form');
            const dropZone = document.getElementById('drop-zone-row');
            let dragCounter = 0;

            filePicker.addEventListener('change', function () {
                this.form.submit();
            });

            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';

            // Drag and drop functionality
            document.body.addEventListener('dragenter', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter++;
                if (dragCounter === 1) {
                    dropZone.style.display = 'block';
                    dropZone.classList.add('drag-over');
                }
            });

            document.body.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
            });

            document.body.addEventListener('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter--;
                if (dragCounter === 0) {
                    dropZone.style.display = 'none';
                    dropZone.classList.remove('drag-over');
                }
            });

            document.body.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter = 0;
                dropZone.style.display = 'none';
                dropZone.classList.remove('drag-over');

                const files = e.dataTransfer.files;
                if (files.length > 0 && files[0].type.startsWith('image/')) {
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(files[0]);
                    filePicker.files = dataTransfer.files;
                    uploadForm.submit();
                }
            });

            document.querySelectorAll('.capturelist-row-metadata-details-seemore').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const detailsText = this.previousElementSibling;
                    detailsText.classList.toggle('expanded');
                    this.textContent = detailsText.classList.contains('expanded') ? 'See Less...' : 'See More...';
                });
            });
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">dreamscroll</h1>

            <form id="file-upload-form" action="/upload" method="post" enctype="multipart/form-data">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker">Upload ⇧</label>
                <div id="submit-btn-container">
                    <br>
                    <input id="submit-btn" type="submit" value="Submit">
                </div>
            </form>
        </div>

        <div id="drop-zone-row">
            Drop image anywhere to upload
        </div>

        {% for capture in capture_infos %}

        <div class="capturelist-row">
            <div class="capturelist-row-image-container">
                <a href="/detail/{{ capture.id }}" style="text-decoration: none; color: inherit;">
                    <img class="capturelist-row-image" src="/media/{{ capture.medias[0].filename }}"
                        alt="image {{ capture.medias[0].filename }}">
                </a>
            </div>
            <div class="capturelist-row-metadata-container">
                {{ capture.created_at }}

                {% if capture.summary %}
                <p>
                    {{ capture.summary }}
                </p>
                {% endif %}

                {% if capture.details %}
                <div class="capturelist-row-metadata-details">
                    <div class="capturelist-row-metadata-details-text">
                        <p>{{ capture.details }}</p>
                    </div>
                    <a href="#" class="capturelist-row-metadata-details-seemore">See More...</a>
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>