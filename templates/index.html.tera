<!DOCTYPE html>
<html>

<head>
    <title>Comprehension</title>
    <style>
        body {
            display: flex;
            justify-content: center;

            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
            font-weight: 400;
            line-height: 1.6;
        }

        #page-content-container {
            display: flex;
            flex-direction: column;
            width: 80%;
            min-width: 480px;
            max-width: 960px;
        }

        #header-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            /* due to .image-row padding */
            width: calc(100% + 20px);
            margin-top: 12px;
            margin-bottom: 20px;
        }

        #page-title {
            margin: 0;
            font-size: xx-large;
            line-height: 1.0;
        }

        #upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #image-file-picker-label {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #image-file-picker-label:hover {
            border-color: #999;
        }

        .image-row {
            width: 100%;
            display: flex;
            flex-direction: row;
            border: 1px solid #ccc;
            border-radius: 8px;
            gap: 10px;
            padding: 10px;
            margin-bottom: 10px;
        }

        .image-actual-wrapper {
            width: 55%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .image-actual {
            width: 100%;
            height: auto;
            max-height: 600px;
            object-fit: contain;
        }

        .image-metadata-wrapper {
            width: 45%;
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            margin-left: 10px;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('image-file-picker').addEventListener('change', function () {
                this.form.submit();
            });

            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">Comprehension</h1>

            <form id="upload-form" action="/upload" method="post" enctype="multipart/form-data">
                <input id="image-file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="image-file-picker-label" for="image-file-picker">Upload ⇧</label>
                <div id="submit-btn-container">
                    <br>
                    <input type="submit" id="submit-btn" value="Submit">
                </div>
            </form>
        </div>

        {% for i in images %}
        <div class="image-row">
            <div class="image-actual-wrapper">
                <img class="image-actual" src="/uploads/{{ i.filename }}" alt="image {{i.filename}}">
            </div>
            <div class="image-metadata-wrapper">
                <div class="image-metadata">
                    {{ i.timestamp }}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>