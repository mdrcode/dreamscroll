<!DOCTYPE html>
<html>

<head>
    <title>Comprehension</title>
    <style>
        body {
            display: flex;
            justify-content: center;

            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
            font-weight: 400;
            line-height: 1.6;
        }

        #page-content-container {
            display: flex;
            flex-direction: column;
            min-width: 480px;
            max-width: 80%;
        }

        #header-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: start;
            width: 100%;
            margin-bottom: 10px;
        }

        #page-title {
            margin: 0;
            font-size: xx-large;
        }

        #upload-form-container {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            margin-top: 5px;
        }

        .image-row {
            width: 100%;
            border: 1px solid #ccc;
            display: flex;
            flex-direction: row;
            border-radius: 8px;
            gap: 10px;
            padding: 10px;
            margin-bottom: 10px;
        }

        .image-actual-wrapper {
            width: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .image-actual {
            max-width: 100%;
            max-height: 600px;
            height: auto;
            object-fit: contain;
        }

        .image-metadata {
            flex: 1;
            padding-left: 10px;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('image-file-picker').addEventListener('change', function () {
                this.form.submit();
            });

            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">Comprehension</h1>
            <div id="upload-form-container">
                <form action="/upload" method="post" enctype="multipart/form-data">
                    <input id="image-file-picker" type="file" name="image" accept="image/*" style="display: none;"
                        required>
                    <label id="image-file-picker-label" for="image-file-picker">Upload ⇧</label>
                    <div id="submit-btn-container">
                        <br>
                        <input type="submit" id="submit-btn" value="Upload and Analyze">
                    </div>
                    <br>
                </form>
            </div>
        </div>

        {% for i in images %}
        <div class="image-row">
            <div class="image-actual-wrapper">
                <img class="image-actual" src="/uploads/{{ i.filename }}" alt="image {{i.filename}}">
            </div>
            <div class="image-metadata">
                {{ i.timestamp }}
            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>