<!DOCTYPE html>
<html>

<head>
    <title>dreamspotting - {{ cm.capture.id }}</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', 'Helvetica Neue', Arial, sans-serif;
            font-weight: 400;
            line-height: 1.6;
            margin: 20px;
        }

        #page-content-container {
            display: flex;
            flex-direction: column;
            width: 80%;
            min-width: 480px;
            max-width: 960px;
        }

        .back-link {
            margin-bottom: 20px;
            font-size: 14px;
        }

        .back-link a {
            color: #0066cc;
            text-decoration: none;
        }

        .back-link a:hover {
            text-decoration: underline;
        }

        .detail-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .image-container {
            display: flex;
            justify-content: center;
            align-items: center;
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 20px;
        }

        .image-container img {
            max-width: 100%;
            height: auto;
            max-height: 800px;
            object-fit: contain;
        }

        .metadata {
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        .metadata h2 {
            margin-top: 0;
            font-size: 18px;
        }

        .metadata-row {
            margin: 10px 0;
        }

        .metadata-label {
            font-weight: 600;
            color: #666;
        }
    </style>
</head>

<body>
    <div id="page-content-container">
        <div class="back-link">
            <a href="/">← Back</a>
        </div>

        <div class="detail-container">
            <div class="image-container">
                <img src="/media/{{ cm.medias[0].filename }}" alt="{{ cm.medias[0].filename }}">
            </div>

            <div class="metadata">
                <h2>Image Details</h2>
                <div class="metadata-row">
                    <span class="metadata-label">Filename:</span> {{ cm.medias[0].filename }}
                </div>
                <div class="metadata-row">
                    <span class="metadata-label">Uploaded:</span> {{ cm.capture.created_at }}
                </div>
            </div>
        </div>
    </div>
</body>

</html>