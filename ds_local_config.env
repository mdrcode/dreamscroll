# This config file is for running dreamscroll locally, via cargo run.
# It is loaded explicity by the code in src/bin/dreamscroll_localdev.rs

# !!! Not here! Put secrets in a separate `.env` file (.gitignore'd)
#JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#ILLUMINATOR_GEMINI_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS

#POSTGRES_USER=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_PASSWORD=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_DB=NOT_HERE_SHOULD_BE_IN_SECRETS

# DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

RUST_LOG=info
PORT=8080

# sqlite or postgres
DB_BACKEND=postgres
DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
# DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS

# local or gcloud
STORAGE_BACKEND=gcloud

STORAGE_LOCAL_FILE_PATH="localdev/media_storage"
STORAGE_LOCAL_URL_PREFIX="/media/"

STORAGE_GCLOUD_EMULATOR_ENDPOINT=http://localhost:4443
STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"

# -----------------------------------------------------------------------------
# Pub/Sub task publishing (used by app when a capture is inserted)
# -----------------------------------------------------------------------------
#
# If both vars below are set, the app will publish a message for each new
# capture to the configured topic. If omitted, publishing is disabled (no-op).
#
# For local Pub/Sub emulator use:
#   PUBSUB_API_BASE_URL=http://localhost:8085
#
# For Google Cloud Pub/Sub production use:
#   PUBSUB_API_BASE_URL=https://pubsub.googleapis.com
# and provide a valid bearer token.

# PUBSUB_PROJECT_ID=dreamscroll-local
# PUBSUB_TOPIC_ID=dreamscroll-illumination
# PUBSUB_API_BASE_URL=http://localhost:8085
# PUBSUB_PUBLISH_BEARER_TOKEN=OPTIONAL_BEARER_TOKEN

# -----------------------------------------------------------------------------
# Pub/Sub push webhook authentication mode
# -----------------------------------------------------------------------------
#
# Effective production endpoint path is:
#   /webhook/illumination/push
# Full URL shape:
#   https://<cloud-run-host>/webhook/illumination/push
#
# Localdev binary deliberately runs with NO auth for /webhook/illumination/push
# (to keep emulator testing simple). Cloudrun binary supports:
#
# 1) OIDC mode (required for cloudrun):
#    Set PUBSUB_PUSH_OIDC_AUDIENCE and optionally service account
#    email + custom JWKS URL.
#
#    - PUBSUB_PUSH_OIDC_AUDIENCE should match the audience value
#      configured on the Pub/Sub push subscription.
#    - PUBSUB_PUSH_OIDC_SERVICE_ACCOUNT_EMAIL should be the push
#      auth service account email configured on the Pub/Sub subscription.
#    - PUBSUB_PUSH_OIDC_JWKS_URL normally not needed; defaults to
#      Google's OIDC cert endpoint.
#
# 2) Missing OIDC audience => cloudrun startup fails fast.

# PUBSUB_PUSH_OIDC_AUDIENCE=https://your-cloudrun-url/webhook/illumination/push
# PUBSUB_PUSH_OIDC_SERVICE_ACCOUNT_EMAIL=pubsub-push@your-project.iam.gserviceaccount.com
# PUBSUB_PUSH_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs