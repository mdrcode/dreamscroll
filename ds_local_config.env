# This config file is for running dreamscroll locally, via cargo run.
# It is loaded explicity by the code in src/bin/dreamscroll_localdev.rs

# !!! Not here! Put secrets in a separate `.env` file (.gitignore'd)
#DREAMSCROLL_JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#DREAMSCROLL_ILLUMINATOR_GEMINI_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS

#POSTGRES_USER=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_PASSWORD=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_DB=NOT_HERE_SHOULD_BE_IN_SECRETS

# DREAMSCROLL_DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

RUST_LOG=info
PORT=8080

# sqlite or postgres
DREAMSCROLL_DB_BACKEND=postgres
DREAMSCROLL_DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
# DREAMSCROLL_DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS

# local or gcloud
DREAMSCROLL_STORAGE_BACKEND=gcloud

DREAMSCROLL_STORAGE_LOCAL_FILE_PATH="localdev/media_storage"
DREAMSCROLL_STORAGE_LOCAL_URL_PREFIX="/media/"

DREAMSCROLL_STORAGE_GCLOUD_EMULATOR_ENDPOINT=http://localhost:4443
DREAMSCROLL_STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"