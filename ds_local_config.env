# This config file is for running dreamscroll locally, via cargo run.
# It is loaded explicity by the code in src/bin/dreamscroll_localdev.rs

# !!! Not here! Put secrets in a separate `.env` file (.gitignore'd)
#DREAMSCROLL_JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#DREAMSCROLL_ILLUMINATOR_GEMINI_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS

#POSTGRES_USER=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_PASSWORD=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_DB=NOT_HERE_SHOULD_BE_IN_SECRETS

# DREAMSCROLL_DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

RUST_LOG=info
PORT=8080

# sqlite or postgres
DREAMSCROLL_DB_BACKEND=postgres
DREAMSCROLL_DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
# DREAMSCROLL_DB_URL_POSTGRES=NOT_HERE_SHOULD_BE_IN_SECRETS

# local or gcloud
DREAMSCROLL_STORAGE_BACKEND=gcloud

DREAMSCROLL_STORAGE_LOCAL_FILE_PATH="localdev/media_storage"
DREAMSCROLL_STORAGE_LOCAL_URL_PREFIX="/media/"

DREAMSCROLL_STORAGE_GCLOUD_EMULATOR_ENDPOINT=http://localhost:4443
DREAMSCROLL_STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"

# -----------------------------------------------------------------------------
# Pub/Sub task publishing (used by app when a capture is inserted)
# -----------------------------------------------------------------------------
#
# If both vars below are set, the app will publish a message for each new
# capture to the configured topic. If omitted, publishing is disabled (no-op).
#
# For local Pub/Sub emulator use:
#   DREAMSCROLL_PUBSUB_API_BASE_URL=http://localhost:8085
#
# For Google Cloud Pub/Sub production use:
#   DREAMSCROLL_PUBSUB_API_BASE_URL=https://pubsub.googleapis.com
# and provide a valid bearer token if required by your deployment model.

# DREAMSCROLL_PUBSUB_PROJECT_ID=dreamscroll-local
# DREAMSCROLL_PUBSUB_TOPIC_ID=dreamscroll-illumination
# DREAMSCROLL_PUBSUB_API_BASE_URL=http://localhost:8085
# DREAMSCROLL_PUBSUB_PUBLISH_BEARER_TOKEN=OPTIONAL_BEARER_TOKEN

# -----------------------------------------------------------------------------
# Pub/Sub push webhook authentication mode (internal webhook receiver)
# -----------------------------------------------------------------------------
#
# Effective production endpoint path is:
#   /internal/illumination/push
# Full URL shape:
#   https://<cloud-run-host>/internal/illumination/push
#
# Localdev binary deliberately runs with NO auth for /internal/illumination/push
# (to keep emulator testing simple). Cloudrun binary supports:
#
# 1) OIDC mode (recommended production-grade):
#    Set DREAMSCROLL_PUBSUB_PUSH_OIDC_AUDIENCE and optionally service account
#    email + custom JWKS URL.
#
#    - DREAMSCROLL_PUBSUB_PUSH_OIDC_AUDIENCE should match the audience value
#      configured on the Pub/Sub push subscription.
#    - DREAMSCROLL_PUBSUB_PUSH_OIDC_SERVICE_ACCOUNT_EMAIL should be the push
#      auth service account email configured on the Pub/Sub subscription.
#    - DREAMSCROLL_PUBSUB_PUSH_OIDC_JWKS_URL normally not needed; defaults to
#      Google's OIDC cert endpoint.
#
# 2) Static bearer token mode (legacy fallback):
#    DREAMSCROLL_PUBSUB_WEBHOOK_BEARER_TOKEN
#
# 3) No auth (disallowed in cloudrun; startup guard fails fast)

# DREAMSCROLL_PUBSUB_PUSH_OIDC_AUDIENCE=https://your-cloudrun-url/internal/illumination/push
# DREAMSCROLL_PUBSUB_PUSH_OIDC_SERVICE_ACCOUNT_EMAIL=pubsub-push@your-project.iam.gserviceaccount.com
# DREAMSCROLL_PUBSUB_PUSH_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
# DREAMSCROLL_PUBSUB_WEBHOOK_BEARER_TOKEN=legacy_static_secret