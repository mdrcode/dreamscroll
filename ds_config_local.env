# This config file is for running dreamscroll locally, via cargo run.
# It is loaded explicity by name in src/bin/dreamscroll_localdev.rs

# !!! Not here! Put secrets in a separate `.env` file (.gitignore'd)
#JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#ILLUMINATOR_GEMINI_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_PASSWORD=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

PROJECT_ID=dreamscroll_local

RUST_LOG=info
PORT=8080

# sqlite or postgres
DB_BACKEND=postgres
DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
POSTGRES_USER=dreamscroll_pg_user
#POSTGRES_PASSWORD=NOT HERE SHOULD BE IN SECRETS
POSTGRES_HOST_PORT=localhost:5432
POSTGRES_DB=dreamscroll_dev1

# local or gcloud
STORAGE_BACKEND=gcloud

STORAGE_LOCAL_FILE_PATH="localdev/media_storage"
STORAGE_LOCAL_URL_PREFIX="/media/"

STORAGE_GCLOUD_EMULATOR_ENDPOINT=http://localhost:4443
STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"

# Pub/Sub Task Queue

PUBSUB_EMULATOR_URL_BASE=http://localhost:8085 # emulator
#PUBSUB_PUBLISH_BEARER_TOKEN=OPTIONAL_BEARER_TOKEN

PUBSUB_TOPIC_ID_NEW_CAPTURE=dreamscroll-new_capture

# Pub/Sub Push Webhook Auth
#
# If AUDIENCE is set, then the WebhookAuth will be configurd and verify
# incoming requests using OIDC tokens. Otherwise, no Auth will be enforced
# (just for local development / emulator testing, not for prod).

# PUBSUB_PUSH_OIDC_AUDIENCE=https://your-cloudrun-url/webhook/illumination/push
# PUBSUB_PUSH_OIDC_SERVICE_ACCOUNT_EMAIL=pubsub-push@your-project.iam.gserviceaccount.com