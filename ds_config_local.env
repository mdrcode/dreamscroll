# This config file is for running dreamscroll locally, via cargo run.

# !!! put secrets in ds_secrets.env (.gitignore'd) to avoid leaking them via git
#DREAMSCROLL_JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#DREAMSCROLL_ILLUMINATOR_GEMINI_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

RUST_LOG=info
PORT=8080

# sqlite or postgres
DREAMSCROLL_DB_BACKEND=sqlite

DREAMSCROLL_DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
# This references the local postgres instance defined in docker-compose.yaml.
# Obviously in production the connection string would come from an external
# secret manager.
DREAMSCROLL_DB_URL_POSTGRES=postgres://dreamscroll_pg_user:dreamwscroll_pg_strong_password@db:5432/dreamscroll_dev1

# local or gcloud
DREAMSCROLL_STORAGE_BACKEND=local

DREAMSCROLL_STORAGE_LOCAL_FILE_PATH="localdev/local_storage_provider"
DREAMSCROLL_STORAGE_LOCAL_URL_PREFIX="/media/"

DREAMSCROLL_STORAGE_GCLOUD_EMULATOR_ENDPOINT=http://localhost:4443
DREAMSCROLL_STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"