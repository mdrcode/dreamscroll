# Loaded by name in src/bin/dreamscroll_web.rs for local dev (`cargo run`)

# !!! Not here! Put secrets in a separate `.env` file (.gitignore'd)
#JWT_SECRET=NOT_HERE_SHOULD_BE_IN_SECRETS
#POSTGRES_PASSWORD=NOT_HERE_SHOULD_BE_IN_SECRETS
#GEMINI_API_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS
#XAI_API_KEY=NOT_HERE_SHOULD_BE_IN_SECRETS
# !!!

RUST_LOG=info
SERVICES=webui,api,webhook
PORT=8080

GCLOUD_PROJECT_ID=mdrcode
GCLOUD_PROJECT_REGION=us-central1

SESSION_ALWAYS_SAVE=true
COOKIE_SECURE=false # for local dev only, should be true in prod

ILLUMINATOR=geminipublicapi
FIRESTARTER=grok

# sqlite or postgres
DB_BACKEND=postgres
DB_URL_SQLITE=localdev/dreamscroll.db?mode=rwc
POSTGRES_USER=dreamscroll_pg_user
#POSTGRES_PASSWORD=NOT HERE SHOULD BE IN SECRETS
POSTGRES_HOST_PORT=localhost:5432
POSTGRES_DB=dreamscroll_dev1

# storage (local or gcloud)
STORAGE_BACKEND=gcloud

STORAGE_LOCAL_FILE_PATH="localdev/media_storage"
STORAGE_LOCAL_URL_PREFIX="/media/"

STORAGE_GCLOUD_EMULATOR=http://localhost:4443
#STORAGE_GCLOUD_PROD_ENDPOINT=https://storage.us-central1.rep.googleapis.com
STORAGE_GCLOUD_BUCKET_NAME="dreamscroll-dev-media1"

# task queue (local, gcloudpubsub, or gcloudtasks)
TASK_BACKEND=local

# search via Gemini Embedding v2 and Vertex AI Vector Search
SEARCH_EMBED_COLLECTION_ID="dreamscroll-dev-collection2"
SEARCH_EMBED_OUTPUT_DIMS=768