{
    "name": "dreamscroll",
    "short_name": "dreamscroll",
    "start_url": "/",
    "scope": "/",
    "display": "standalone",
    "background_color": "#fbf9f6",
    "theme_color": "#1a1917",
    "icons": [
        {
            "src": "/static/app-icon.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "any maskable"
        }
    ],
    "share_target": {
        "action": "/upload",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "files": [
                {
                    "name": "image",
                    "accept": [
                        "image/*"
                    ]
                }
            ]
        }
    }
}