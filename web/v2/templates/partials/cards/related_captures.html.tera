<section class="related-captures" data-related-captures>
    <p class="metadata-subsection-title">Related Captures</p>

    <div class="empty-state related-captures__empty" hidden>No related captures found.</div>
    <div class="related-captures__grid" aria-label="Related capture gallery"></div>

    <script type="application/json" class="related-captures__data">{{ captures | json_encode | safe }}</script>
</section>
