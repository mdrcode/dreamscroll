<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>dreamscroll v2</title>
    <link rel="stylesheet" href="/v2/static/dreamscroll.css?v={{ static_asset_version | urlencode }}">
    <script defer src="https://unpkg.com/htmx.org@2.0.7" integrity="sha384-ZBXiYtYQ6hJ2Y0ZNoYuI+Nq5MqWBr+chMrS/RkXpNzQCApHEhOt2aY8EJgqwHLkJ" crossorigin="anonymous"></script>
    <script defer src="/v2/static/webui.js?v={{ static_asset_version | urlencode }}"></script>
</head>

<body>
    <div id="page-content-container">
        <div id="header-row">
            <h1 id="page-title"><a href="/v2" class="header-title-link">dreamscroll / v2</a></h1>

            <form id="file-upload-form"
                action="/v2/upload"
                method="post"
                enctype="multipart/form-data"
                hx-post="/v2/upload"
                hx-encoding="multipart/form-data"
                hx-target="#card-feed"
                hx-swap="innerHTML">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker">
                    <span class="file-picker-text">Upload</span>
                    <span class="file-picker-icon">⇧</span>
                </label>
            </form>

            <form id="header-search-form" action="/v2/cards/feed" method="get"
                hx-get="/v2/cards/feed"
                hx-target="#card-feed"
                hx-swap="innerHTML"
                hx-push-url="false">
                <input type="hidden" id="feed-mode-input" name="mode" value="{{ feed_mode | default(value="blend") }}">
                <input id="header-search-input"
                    type="text"
                    name="q"
                    value="{{ query }}"
                    placeholder="search..."
                    hx-get="/v2/cards/feed"
                    hx-target="#card-feed"
                    hx-trigger="keyup changed delay:300ms"
                    hx-swap="innerHTML"
                    hx-push-url="false">
            </form>
        </div>

        <div id="feed-controls">
            <button type="button"
                class="feed-action{% if feed_mode == "captures" %} feed-action--active{% endif %}"
                data-feed-mode="captures"
                hx-get="/v2/cards/feed?mode=captures&n=30"
                hx-target="#card-feed"
                hx-swap="innerHTML"
                hx-push-url="false">Captures Only</button>
            <button type="button"
                class="feed-action{% if feed_mode == "sparks" %} feed-action--active{% endif %}"
                data-feed-mode="sparks"
                hx-get="/v2/cards/feed?mode=sparks&n=30"
                hx-target="#card-feed"
                hx-swap="innerHTML"
                hx-push-url="false">Sparks Only</button>
        </div>

        <div id="drop-zone-row">Drop image anywhere to upload</div>

        <div id="card-feed">
            {% include "partials/feed.html.tera" %}
        </div>
    </div>
</body>

</html>
