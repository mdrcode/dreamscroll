<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>dreamscroll v2</title>
    <link rel="stylesheet" href="/v2/static/dreamscroll.css?v={{ static_asset_version | urlencode }}">
    <script defer src="https://unpkg.com/htmx.org@2.0.7" integrity="sha384-ZBXiYtYQ6hJ2Y0ZNoYuI+Nq5MqWBr+chMrS/RkXpNzQCApHEhOt2aY8EJgqwHLkJ" crossorigin="anonymous"></script>
    <script defer src="/v2/static/webui.js?v={{ static_asset_version | urlencode }}"></script>
</head>

<body>
    <div id="page-content-container">
        <div id="header-row">
            <h1 id="page-title"><a href="/v2" class="header-title-link">dreamscroll / v2</a></h1>

            <form id="file-upload-form"
                action="/v2/upload"
                method="post"
                enctype="multipart/form-data">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker">
                    <span class="file-picker-text">Upload</span>
                    <span class="file-picker-icon">⇧</span>
                </label>
            </form>

            <form id="header-search-form" action="/v2/cards" method="get"
                hx-get="/v2/cards"
                hx-target="#card-feed"
                hx-swap="innerHTML"
                hx-push-url="false"
                hx-trigger="submit">
                <input type="hidden" name="n" value="30">
                <input type="hidden" id="feed-mode-input" name="content" value="{{ content_mode | default(value="blend") }}">
                <input id="header-search-input"
                    type="text"
                    name="q"
                    value="{{ query }}"
                    placeholder="search...">
            </form>
        </div>

        <div id="upload-progress" aria-live="polite" aria-label="Upload progress">
            <div id="upload-progress-track">
                <div id="upload-progress-bar"></div>
            </div>
            <div id="upload-progress-text">0%</div>
        </div>

        <div id="feed-controls"{% if is_search_mode %} style="display: none;"{% endif %}>
            <button type="button"
                class="feed-action{% if content_mode == "captures" %} feed-action--active{% endif %}"
                data-feed-mode="captures">Captures Only</button>
            <button type="button"
                class="feed-action{% if content_mode == "sparks" %} feed-action--active{% endif %}"
                data-feed-mode="sparks">Sparks Only</button>
        </div>

        <div id="drop-zone-row">Drop image anywhere to upload</div>

        <div id="card-feed">
            {% include "partials/feed.html.tera" %}
        </div>
    </div>
</body>

</html>
