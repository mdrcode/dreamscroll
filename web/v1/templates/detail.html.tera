<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>dreamscroll - {{ capture.id }}</title>
    <link rel="stylesheet" href="/static/common.css">
    <style>
        #page-content-container {
            max-width: 960px;
        }

        .detail-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .image-container {
            display: flex;
            justify-content: center;
            align-items: center;
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 20px;
            background: #fff;
        }

        .image-container img {
            max-width: 100%;
            height: auto;
            max-height: 800px;
            object-fit: contain;
        }

        .metadata {
            padding: 20px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        .metadata h2 {
            margin-top: 0;
            font-size: 18px;
        }

        .metadata-row {
            margin: 10px 0;
        }

        .metadata-label {
            font-weight: 600;
            color: #666;
        }

        .detail-timestamp {
            font-size: 13px;
            color: #888;
        }

        .detail-summary {
            font-size: 16px;
            line-height: 1.6;
            margin: 16px 0;
        }

        .detail-details {
            font-size: 15px;
            line-height: 1.6;
            color: #444;
            margin: 16px 0;
            white-space: pre-wrap;
        }

        .detail-section-label {
            font-size: 12px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .detail-queries {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 16px 0;
        }

        .detail-query-pill {
            font-size: 13px;
            color: #4a5568;
            background: #edf2f7;
            padding: 6px 12px;
            border-radius: 14px;
            text-decoration: none;
            transition: background 0.15s ease;
        }

        .detail-query-pill:hover {
            background: #e2e8f0;
            color: #2d3748;
        }

        .detail-entities {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 16px 0;
        }

        .detail-entity {
            display: inline-flex;
            align-items: center;
            font-size: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            overflow: hidden;
            text-decoration: none;
            color: inherit;
            transition: border-color 0.15s ease;
        }

        .detail-entity:hover {
            border-color: #cbd5e0;
        }

        .detail-entity-type {
            background: #f7fafc;
            color: #718096;
            padding: 4px 8px;
            text-transform: lowercase;
            font-size: 11px;
            letter-spacing: 0.3px;
        }

        .detail-entity-name {
            padding: 4px 10px;
            color: #2d3748;
            font-weight: 500;
        }

        .detail-entity-desc {
            display: block;
            font-size: 11px;
            color: #666;
            margin-top: 2px;
        }

        @media (max-width: 700px) {
            #page-content-container {
                max-width: 100%;
            }

            .detail-container {
                gap: 12px;
            }

            .image-container {
                border-radius: 6px;
                padding: 4px;
            }

            .image-container img {
                max-height: 74vh;
            }

            .metadata {
                padding: 12px;
                border-radius: 6px;
            }

            .metadata h2 {
                font-size: 16px;
                margin-bottom: 8px;
            }

            .metadata-row {
                margin: 6px 0;
            }

            .detail-summary {
                font-size: 15px;
                line-height: 1.45;
                margin: 10px 0;
            }

            .detail-details {
                font-size: 14px;
                line-height: 1.45;
                margin: 10px 0;
            }

            .detail-queries,
            .detail-entities {
                margin: 10px 0;
                gap: 6px;
            }
        }
    </style>
</head>

<body>
    <div id="page-content-container">
        <div id="header-row">
            <h1 id="page-title">dreamscroll - {{ capture.id }}</h1>
        </div>

        <div class="back-link">
            <a href="/">← Back</a>
        </div>

        <div class="detail-container">
            <div class="image-container">
                <img src="{{ capture.medias[0].url }}" alt="{{ capture.medias[0].storage_uuid }}">
            </div>

            <div class="metadata">
                <h2>Image Details</h2>
                <div class="metadata-row">
                    <span class="metadata-label">Filename:</span> {{ capture.medias[0].storage_uuid }}
                </div>
                <div class="metadata-row">
                    <span class="metadata-label">Uploaded:</span>
                    <span class="detail-timestamp">{{ capture.created_at }}</span>
                </div>

                {% if capture.illuminations | length > 0 %}
                {% set illum = capture.illuminations | first %}

                {% if illum.summary %}
                <div class="detail-summary">{{ illum.summary }}</div>
                {% endif %}

                {% if illum.details %}
                <div class="detail-details">{{ illum.details }}</div>
                {% endif %}

                {% if illum.x_queries | length > 0 %}
                <div class="detail-section-label">Suggested Searches</div>
                <div class="detail-queries">
                    {% for query in illum.x_queries %}
                    <a href="https://www.google.com/search?q={{ query | urlencode }}" target="_blank" class="detail-query-pill">{{ query }}</a>
                    {% endfor %}
                </div>
                {% endif %}

                {% if illum.k_nodes | length > 0 %}
                <div class="detail-section-label">Entities</div>
                <div class="detail-entities">
                    {% for node in illum.k_nodes %}
                    <a href="/entity/knode/{{ node.id }}" class="detail-entity">
                        <span class="detail-entity-type">{{ node.k_type }}</span>
                        <span class="detail-entity-name">{{ node.name }}</span>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}

                {% if illum.social_medias | length > 0 %}
                <div class="detail-section-label">Social Media</div>
                <div class="detail-entities">
                    {% for node in illum.social_medias %}
                    <a href="/entity/social/{{ node.id }}" class="detail-entity">
                        <span class="detail-entity-type">{{ node.platform }}</span>
                        <span class="detail-entity-name">{{ node.display_name }}</span>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}

                {% else %}
                <div class="metadata-row">No illumination data available.</div>
                {% endif %}
            </div>
        </div>
    </div>
</body>

</html>