<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>dreamscroll - {{ capture.id }}</title>
    <link rel="stylesheet" href="/static/dreamscroll-v1.css?v={{ static_asset_version | urlencode }}">
    <style>
        #page-content-container {
            max-width: 960px;
        }

        .detail-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding: 16px;
            border-radius: 10px;
            background: var(--color-capture-row-bg);
            box-shadow: 0 1px 4px var(--color-capture-row-shadow);
        }

        .image-container {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 0;
        }

        .image-container img {
            max-width: 100%;
            height: auto;
            max-height: 800px;
            object-fit: contain;
            border-radius: 10px;
        }

        .metadata {
            padding: 0;
        }

        .metadata h2 {
            margin-top: 0;
            font-size: 18px;
        }

        .metadata-row {
            margin: 10px 0;
        }

        .metadata-label {
            font-weight: 600;
            color: var(--color-page-text);
        }

        .detail-timestamp {
            font-size: 13px;
            color: var(--color-page-text);
        }

        .detail-summary {
            font-size: 15px;
            line-height: 1.35;
            margin: 12px 0;
        }

        .detail-details {
            font-size: 15px;
            line-height: 1.35;
            color: var(--color-page-text);
            margin: 12px 0;
            white-space: pre-line;
        }

        @media (max-width: 768px) {
            #page-content-container {
                max-width: 100%;
            }

            .detail-container {
                gap: 10px;
                padding: 12px;
            }

            .image-container {
                padding: 0;
            }

            .image-container img {
                max-height: 960px;
                border-radius: 10px;
            }

            .metadata {
                padding: 0;
            }

            .metadata h2 {
                font-size: 16px;
                margin-bottom: 8px;
            }

            .metadata-row {
                margin: 6px 0;
            }

            .detail-summary {
                font-size: 15px;
                margin: 10px 0;
            }

            .detail-details {
                font-size: 15px;
                margin: 10px 0;
            }

        }

        @media (min-width: 769px) {
            .detail-summary,
            .detail-details {
                line-height: 1.5;
            }
        }
    </style>
</head>

<body>
    <div id="page-content-container">
        <div id="header-row">
            <h1 id="page-title"><a href="/" class="header-title-link">dreamscroll</a> - {{ capture.id }}</h1>
        </div>

        <div class="detail-container">
            <div class="image-container">
                <img src="{{ capture.medias[0].url }}" alt="{{ capture.medias[0].storage_uuid }}">
            </div>

            <div class="metadata">
                <h2>Image Details</h2>
                <div class="metadata-row">
                    <span class="metadata-label">Filename:</span> {{ capture.medias[0].storage_uuid }}
                </div>
                <div class="metadata-row">
                    <span class="metadata-label">Uploaded:</span>
                    <span class="detail-timestamp" title="{{ capture.created_at }}">{{ capture.created_at_human }}</span>
                </div>

                {% if capture.illuminations | length > 0 %}
                {% set illum = capture.illuminations | first %}

                {% if illum.summary %}
                <div class="detail-summary">{{ illum.summary }}</div>
                {% endif %}

                {% if illum.details %}
                <div class="detail-details">{{ illum.details }}</div>
                {% endif %}

                {% if illum.x_queries | length > 0 %}
                <div class="section-label">Suggested Searches</div>
                <div class="pill-group pill-group--wrap pill-group--queries pill-group--section">
                    {% for query in illum.x_queries %}
                    <a href="https://www.google.com/search?q={{ query | urlencode }}" target="_blank" rel="noopener noreferrer" class="pill"><span class="pill__label">{{ query }}</span></a>
                    {% endfor %}
                </div>
                {% endif %}

                {% if illum.k_nodes | length > 0 %}
                <div class="section-label">Entities</div>
                <div class="pill-group pill-group--wrap pill-group--section">
                    {% for node in illum.k_nodes %}
                    <a href="/entity/knode/{{ node.id }}" class="pill">
                        <span class="pill__prefix">{{ node.k_type }}</span>
                        <span class="pill__label">{{ node.name }}</span>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}

                {% if illum.social_medias | length > 0 %}
                <div class="section-label">Social Media</div>
                <div class="pill-group pill-group--wrap pill-group--section">
                    {% for node in illum.social_medias %}
                    <a href="/entity/social/{{ node.id }}" class="pill">
                        <span class="pill__prefix">{{ node.platform }}</span>
                        <span class="pill__label">{{ node.display_name }}</span>
                    </a>
                    {% endfor %}
                </div>
                {% endif %}

                {% else %}
                <div class="metadata-row">No illumination data available.</div>
                {% endif %}
            </div>
        </div>
    </div>
</body>

</html>