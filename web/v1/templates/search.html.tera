<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Search - dreamscroll</title>
    <link rel="stylesheet" href="/static/common.css">
    <link rel="stylesheet" href="/static/capturelist.css">
    <style>
        #page-content-container {
            width: 80%;
            min-width: 480px;
            max-width: 800px;
        }

        #search-form {
            display: flex;
            flex-direction: row;
            gap: 10px;
            /* due to mysterious padding issue in .capturelist ... */
            width: calc(100% + 20px);
            margin-bottom: 20px;
        }

        #search-input {
            flex: 1;
            padding: 10px 14px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        #search-input:focus {
            outline: none;
            border-color: #007bff;
        }

        #search-btn {
            padding: 10px 20px;
            font-size: 16px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        #search-btn:hover {
            background-color: #0056b3;
        }

        .result-count {
            color: #666;
            margin-bottom: 20px;
        }

        .no-results {
            color: #666;
            font-style: italic;
            padding: 20px 0;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('search-input');

            // Focus search input on "/" key press
            document.addEventListener('keydown', function (e) {
                if (e.key === '/' && document.activeElement !== searchInput) {
                    e.preventDefault();
                    searchInput.focus();
                }
            });

            // "See More"/"See Less" toggle for capture details
            document.querySelectorAll('.capturelist-row-metadata-details-seemore').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const detailsText = this.previousElementSibling;
                    detailsText.classList.toggle('expanded');
                    this.textContent = detailsText.classList.contains('expanded') ? 'See Less...' : 'See More...';
                });
            });
        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title"><a href="/" style="text-decoration: none; color: inherit;">dreamscroll</a></h1>
        </div>

        <form id="search-form" action="/search" method="get">
            <input type="text" id="search-input" name="q" placeholder="Search illuminations..." {% if query
                %}value="{{ query }}" {% else %} autofocus {% endif %}>
            <button type="submit" id="search-btn">Search</button>
        </form>

        {% if query %}
        <div class="result-count">
            Found {{ result_count }} result{% if result_count != 1 %}s{% endif %} for "{{ query }}"
        </div>

        {% if capture_infos | length == 0 %}
        <div class="no-results">
            No results found. Try a different search term.
        </div>
        {% endif %}
        {% endif %}

        {% for capture in capture_infos %}
        <div class="capturelist-row">
            <div class="capturelist-row-image-container">
                <a href="/detail/{{ capture.id }}" style="text-decoration: none; color: inherit;">
                    <img class="capturelist-row-image" src="{{ capture.medias[0].url }}"
                        alt="image {{ capture.medias[0].url }}">
                </a>
            </div>
            <div class="capturelist-row-metadata-container">
                <span class="capturelist-row-timestamp">{{ capture.created_at }}</span>

                {% if capture.illuminations | length > 0 %}
                    {% set illum = capture.illuminations | first %}

                    {% if illum.summary %}
                    <p class="capturelist-row-summary">{{ illum.summary }}</p>
                    {% endif %}

                    {% if illum.details %}
                    <div class="capturelist-row-metadata-details">
                        <div class="capturelist-row-metadata-details-text">
                            <p>{{ illum.details }}</p>
                        </div>
                        <a href="#" class="capturelist-row-metadata-details-seemore">See More...</a>
                    </div>
                    {% endif %}

                    {% if illum.k_nodes | length > 0 %}
                    <div class="capturelist-row-entities">
                        {% for node in illum.k_nodes %}
                        <a href="/entity/knode/{{ node.id }}" class="capturelist-entity" title="{{ node.description }}">
                            <div class="capturelist-entity-type">{{ node.k_type }}</div>
                            <div class="capturelist-entity-name">{{ node.name }}</div>
                        </a>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if illum.social_medias | length > 0 %}
                    <div class="capturelist-row-entities">
                        {% for node in illum.social_medias %}
                        <a href="/entity/social/{{ node.id }}" class="capturelist-entity" title="{{ node.handle }}">
                            <div class="capturelist-entity-type">{{ node.platform }}</div>
                            <div class="capturelist-entity-name">{{ node.display_name }}</div>
                        </a>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if illum.x_queries | length > 0 %}
                    <div class="capturelist-row-queries">
                        {% for query in illum.x_queries %}
                        <a href="https://www.google.com/search?q={{ query | urlencode }}" target="_blank" class="capturelist-query-pill">{{ query }}</a>
                        {% endfor %}
                    </div>
                    {% endif %}
                {% endif %}

            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>