<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>dreamscroll</title>
    <link rel="stylesheet" href="/static/dreamscroll.css?v={{ static_asset_version | urlencode }}">
    <style>
        #page-content-container {
            max-width: 800px;
        }

        #header-search-form {
            display: flex;
            flex-direction: row;
            gap: 10px;
            flex: 1;
            min-width: 0;
            max-width: 420px;
            margin-bottom: 0;
        }

        #header-search-input {
            width: 100%;
            box-sizing: border-box;
            padding: 7px 14px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        #header-search-input:focus {
            outline: none;
            border-color: #007bff;
        }

        #file-upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #submit-btn-container {
            display: none;
        }

        #file-picker-label {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid #ddd;
            background-color: #fff;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #file-picker-label:hover {
            border-color: #999;
            background-color: #f8fafc;
        }

        #drop-zone-row {
            display: none;
            width: 100%;
            text-align: center;
            font-size: 18px;
            background-color: #f9f9f9;
            color: #666;

            padding: 20px 0;
            margin-bottom: 20px;

            border: 2px dashed #ccc;
            border-radius: 8px;
        }

        #drop-zone.drag-over {
            display: block;
            border-color: #999;
            background-color: #f0f0f0;
        }

        @media (max-width: 768px) {
            #header-row {
                flex-wrap: wrap;
                align-items: center;
                row-gap: 2px;
            }

            #header-search-form {
                width: 100%;
                max-width: none;
                flex-basis: 100%;
                order: 3;
                margin-top: 6px;
                margin-bottom: 4px;
            }

            #header-search-input {
                width: 100%;
                box-sizing: border-box;
                font-size: 15px;
                padding: 9px 12px;
            }

            #file-picker-label {
                padding: 6px 10px;
            }

            .file-picker-text {
                display: none;
            }

            #file-picker-label {
                gap: 0;
                min-width: 34px;
                justify-content: center;
            }
        }
    </style>
    <script defer src="/static/webui.js?v={{ static_asset_version | urlencode }}"></script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">dreamscroll</h1>

            <form id="file-upload-form" action="/upload" method="post" enctype="multipart/form-data">
                <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                <label id="file-picker-label" for="file-picker"><span class="file-picker-text">Upload</span><span class="file-picker-icon">⇧</span></label>
                <div id="submit-btn-container">
                    <br>
                    <input id="submit-btn" type="submit" value="Submit">
                </div>
                <noscript>
                    <style>
                        #submit-btn-container {
                            display: block;
                        }
                    </style>
                </noscript>
            </form>

            <form id="header-search-form" action="/search" method="get">
                <input id="header-search-input" type="text" name="q" placeholder="search...">
            </form>
        </div>

        <div id="drop-zone-row">
            Drop image anywhere to upload
        </div>

        {% for capture in capture_infos %}

        <div class="capturelist-row">
            <div class="capturelist-row-image-container">
                <a href="/detail/{{ capture.id }}" style="text-decoration: none; color: inherit;">
                    <img class="capturelist-row-image" src="{{ capture.medias[0].url }}"
                        alt="image {{ capture.medias[0].storage_uuid }}">
                </a>
            </div>
            <div class="capturelist-row-metadata-container">
                {% if capture.illuminations | length > 0 %}
                    {% set illum = capture.illuminations | first %}
                    {% set knode_count = illum.k_nodes | length %}
                    {% set social_count = illum.social_medias | length %}
                    {% set query_count = illum.x_queries | length %}
                    {% set has_details = illum.details %}

                    {% if illum.summary %}
                    <p class="capturelist-row-summary">
                        {{ illum.summary }}{% if has_details %}<a href="#" class="capturelist-row-seemore">See More...</a>{% endif %}
                    </p>
                    {% endif %}

                    {% if has_details %}
                    <div class="capturelist-row-expandable">
                        <div class="capturelist-row-metadata-details">
                            <p>{{ illum.details }}</p>
                        </div>
                    </div>
                    {% endif %}

                    {% if knode_count > 0 or social_count > 0 or query_count > 0 %}
                        {% if knode_count > 0 %}
                        <div class="capturelist-row-entities">
                            {% for node in illum.k_nodes %}
                            <a href="/entity/knode/{{ node.id }}" class="capturelist-entity" title="{{ node.description }}">
                                <div class="capturelist-entity-type">{{ node.k_type }}</div>
                                <div class="capturelist-entity-name">{{ node.name }}</div>
                            </a>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {% if social_count > 0 %}
                        <div class="capturelist-row-entities">
                            {% for node in illum.social_medias %}
                            <a href="/entity/social/{{ node.id }}" class="capturelist-entity" title="{{ node.handle }}">
                                <div class="capturelist-entity-type">{{ node.platform }}</div>
                                <div class="capturelist-entity-name">{{ node.display_name }}</div>
                            </a>
                            {% endfor %}
                        </div>
                        {% endif %}

                        {% if query_count > 0 %}
                        <div class="capturelist-row-queries">
                            {% for query in illum.x_queries %}
                            <a href="https://www.google.com/search?q={{ query | urlencode }}" target="_blank" rel="noopener noreferrer" class="capturelist-query-pill"><span class="capturelist-query-text">{{ query }}</span></a>
                            {% endfor %}
                        </div>
                        {% endif %}
                    {% endif %}

                {% endif %}

                <span class="capturelist-row-timestamp" title="{{ capture.created_at }}">{{ capture.created_at_human }}</span>

            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>