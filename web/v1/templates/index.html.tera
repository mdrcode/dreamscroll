<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>dreamscroll</title>
    <link rel="stylesheet" href="/static/common.css">
    <link rel="stylesheet" href="/static/capturelist.css">
    <style>
        #page-content-container {
            width: 80%;
            min-width: 480px;
            max-width: 800px;
        }

        #header-action-bar {
            display: flex;
            flex-direction: row;
            align-items: end;
            gap: 20px;
            padding-bottom: 2px;
        }

        #header-search-form {
            display: flex;
            flex-direction: row;
            gap: 10px;
        }

        #header-search-input {
            padding: 7px 14px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }

        #header-search-input:focus {
            outline: none;
            border-color: #007bff;
        }

        #file-upload-form {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        #file-picker-label {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 4px 8px;
            cursor: pointer;
        }

        #file-picker-label:hover {
            border-color: #999;
        }

        #drop-zone-row {
            display: none;
            width: 100%;
            text-align: center;
            font-size: 18px;
            background-color: #f9f9f9;
            color: #666;

            padding: 20px 0;
            margin-bottom: 20px;

            border: 2px dashed #ccc;
            border-radius: 8px;
        }

        #drop-zone.drag-over {
            display: block;
            border-color: #999;
            background-color: #f0f0f0;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // File upload auto-submit on file selection without explicit submit button
            const filePicker = document.getElementById('file-picker');
            filePicker.addEventListener('change', function () {
                this.form.submit();
            });
            // If JS enabled, form will auto submit (as above) so can hide explicit button
            document.getElementById('submit-btn-container').style.display = 'none';

            // Drag and drop functionality
            const uploadForm = document.getElementById('file-upload-form');
            const dropZone = document.getElementById('drop-zone-row');
            let dragCounter = 0;
            document.body.addEventListener('dragenter', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter++;
                if (dragCounter === 1) {
                    dropZone.style.display = 'block';
                    dropZone.classList.add('drag-over');
                }
            });

            document.body.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
            });

            document.body.addEventListener('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter--;
                if (dragCounter === 0) {
                    dropZone.style.display = 'none';
                    dropZone.classList.remove('drag-over');
                }
            });

            document.body.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dragCounter = 0;
                dropZone.style.display = 'none';
                dropZone.classList.remove('drag-over');

                const files = e.dataTransfer.files;
                if (files.length > 0 && files[0].type.startsWith('image/')) {
                    const dataTransfer = new DataTransfer();
                    dataTransfer.items.add(files[0]);
                    filePicker.files = dataTransfer.files;
                    uploadForm.submit();
                }
            });


            // Focus search input on "/" key press
            const searchInput = document.getElementById('header-search-input');
            document.addEventListener('keydown', function (e) {
                if (e.key === '/' && document.activeElement !== searchInput) {
                    e.preventDefault();
                    searchInput.focus();
                }
            });

            // "See More"/"See Less" toggle for capture details
            document.querySelectorAll('.capturelist-row-metadata-details-seemore').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const detailsText = this.previousElementSibling;
                    detailsText.classList.toggle('expanded');
                    this.textContent = detailsText.classList.contains('expanded') ? 'See Less...' : 'See More...';
                });
            });


        });
    </script>
</head>

<body>
    <div id="page-content-container">

        <div id="header-row">
            <h1 id="page-title">dreamscroll</h1>

            <div id="header-action-bar">

                <form id="file-upload-form" action="/upload" method="post" enctype="multipart/form-data">
                    <input id="file-picker" type="file" name="image" accept="image/*" style="display: none;" required>
                    <label id="file-picker-label" for="file-picker">Upload ⇧</label>
                    <div id="submit-btn-container">
                        <br>
                        <input id="submit-btn" type="submit" value="Submit">
                    </div>
                </form>

                <form id="header-search-form" action="/search" method="get">
                    <input id="header-search-input" type="text" name="q" placeholder="search...">
                </form>

            </div>
        </div>

        <div id="drop-zone-row">
            Drop image anywhere to upload
        </div>

        {% for capture in capture_infos %}

        <div class="capturelist-row">
            <div class="capturelist-row-image-container">
                <a href="/detail/{{ capture.id }}" style="text-decoration: none; color: inherit;">
                    <img class="capturelist-row-image" src="/media/{{ capture.medias[0].filename }}"
                        alt="image {{ capture.medias[0].filename }}">
                </a>
            </div>
            <div class="capturelist-row-metadata-container">
                <span class="capturelist-row-timestamp">{{ capture.created_at }}</span>

                {% if capture.illuminations | length > 0 %}
                    {% set illum = capture.illuminations | first %}

                    {% if illum.summary %}
                    <p class="capturelist-row-summary">{{ illum.summary }}</p>
                    {% endif %}

                    {% if illum.details %}
                    <div class="capturelist-row-metadata-details">
                        <div class="capturelist-row-metadata-details-text">
                            <p>{{ illum.details }}</p>
                        </div>
                        <a href="#" class="capturelist-row-metadata-details-seemore">See More...</a>
                    </div>
                    {% endif %}
                {% endif %}

                {% if capture.k_nodes | length > 0 %}
                <div class="capturelist-row-entities">
                    {% for node in capture.k_nodes %}
                    <span class="capturelist-entity" title="{{ node.description }}">
                        <span class="capturelist-entity-type">{{ node.k_type }}</span>
                        <span class="capturelist-entity-name">{{ node.name }}</span>
                    </span>
                    {% endfor %}
                </div>
                {% endif %}

                {% if capture.social_medias | length > 0 %}
                <div class="capturelist-row-entities">
                    {% for node in capture.social_medias %}
                    <span class="capturelist-entity" title="{{ node.handle }}">
                        <span class="capturelist-entity-type">{{ node.platform }}</span>
                        <span class="capturelist-entity-name">{{ node.display_name }}</span>
                    </span>
                    {% endfor %}
                </div>
                {% endif %}

                {% if capture.x_queries | length > 0 %}
                <div class="capturelist-row-queries">
                    {% for query in capture.x_queries %}
                    <a href="https://www.google.com/search?q={{ query | urlencode }}" target="_blank" class="capturelist-query-pill">{{ query }}</a>
                    {% endfor %}
                </div>
                {% endif %}

            </div>
        </div>
        {% endfor %}
    </div>
</body>

</html>